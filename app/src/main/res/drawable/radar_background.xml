<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F5F5F5" /> <!-- Light background color -->
        </shape>
    </item>

    <!-- Circular radar ring -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#4CAF50" /> <!-- Outer ring in green -->
            <solid android:color="#00FFFFFF" /> <!-- Transparent fill -->
        </shape>
        <padding android:left="16dp" android:right="16dp" android:top="16dp" android:bottom="16dp" />
    </item>

    <!-- Inner cross lines (you can stack more for a grid-like effect) -->
    <item android:drawable="@android:drawable/divider_horizontal_dark"
        android:gravity="center_horizontal" />
    <item android:drawable="@android:drawable/divider_horizontal_dark"
        android:gravity="center_vertical" />
</layer-list>